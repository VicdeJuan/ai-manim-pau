% --- Comando para la Tabla de Datos ---
\newcommand{\TablaDatos}[6]{
    \noindent
    \begin{tabularx}{\textwidth}{|p{2.2cm}|X|p{3.2cm}|X|}
        \hline
        \textbf{Titulación:} & #1 & \textbf{Curso:} & #2 \\ \hline
        \textbf{Módulo:} & #3 & \textbf{Fecha:} & #4 \\ \hline
        \textbf{Examen:} & #5 & \textbf{Duración:} & #6 \\ \hline
        \textbf{Nombre:} & & \cellcolor{grisclaro} \textbf{Calificación:} & \cellcolor{grisclaro} \\ \hline
        \textbf{Apellidos:} & \multicolumn{3}{l|}{} \\ \hline
        \textbf{RAs:} & \multicolumn{3}{l|}{} \\ \hline
    \end{tabularx}
}

% --- Sección de Normas ---
\newcommand{\NormasEInstrucciones}[1]{
    \vspace{0.5cm}
    \noindent
    \begin{tabularx}{\textwidth}{|X|}
        \hline
        \textbf{\underline{NORMAS E INSTRUCCIONES. LEER ATENTAMENTE, POR FAVOR}} \\
        \begin{itemize}[label=$\blacksquare$, leftmargin=1cm, nosep, after=\vspace{0.2cm}]
            #1
        \end{itemize} \\ \hline
    \end{tabularx}
    \vspace{0.5cm}
}

